<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
		PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fms.system.mapper.DeviceMapper">

	<resultMap type="Device" id="DeviceResult">
		<id     property="id"           column="id"          />
		<result property="deviceId"     column="device_id"   />
		<result property="name"         column="name"        />
		<result property="type"         column="type"        />
		<result property="lastComTime"  column="last_com_time"/>
		<result property="batteryLevel" column="battery_level"/>
		<result property="pressure"     column="pressure"    />
		<result property="status"       column="status"      />
		<result property="createBy"     column="create_by"   />
		<result property="createTime"   column="create_time" />
		<result property="updateBy"     column="update_by"   />
		<result property="updateTime"   column="update_time" />
		<result property="remark"       column="remark"      />
	</resultMap>

	<sql id="selectDeviceVo">
		select id, device_id, name, type, last_com_time, battery_level, pressure, status,
			   create_by, create_time, update_by, update_time
		from device
	</sql>

	<!-- 查询装置列表 -->
	<select id="selectDeviceList" parameterType="Device" resultMap="DeviceResult">
		<include refid="selectDeviceVo"/>
		<where>
			<if test="deviceId != null and deviceId != ''">
				AND device_id like concat('%', #{deviceId}, '%')
			</if>
			<if test="name != null and name != ''">
				AND name like concat('%', #{name}, '%')
			</if>
			<if test="type != null and type != ''">
				AND type = #{type}
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
		</where>
		order by id desc
	</select>

	<!-- 根据ID查询装置 -->
	<select id="selectDeviceById" parameterType="Long" resultMap="DeviceResult">
		<include refid="selectDeviceVo"/>
		where id = #{id}
	</select>

	<!-- 检查装置ID唯一性 -->
	<select id="checkDeviceIdUnique" parameterType="String" resultMap="DeviceResult">
		<include refid="selectDeviceVo"/>
		where device_id = #{deviceId} limit 1
	</select>

	<!-- 新增装置 -->
	<insert id="insertDevice" parameterType="Device" useGeneratedKeys="true" keyProperty="id">
		insert into device (
		<if test="deviceId != null and deviceId != ''">device_id,</if>
		<if test="name != null and name != ''">name,</if>
		<if test="type != null and type != ''">type,</if>
		<if test="lastComTime != null">last_com_time,</if>
		<if test="batteryLevel != null">battery_level,</if>
		<if test="pressure != null">pressure,</if>
		<if test="status != null and status != ''">status,</if>
		<if test="createBy != null and createBy != ''">create_by,</if>
		create_time
		) values (
		<if test="deviceId != null and deviceId != ''">#{deviceId},</if>
		<if test="name != null and name != ''">#{name},</if>
		<if test="type != null and type != ''">#{type},</if>
		<if test="lastComTime != null">#{lastComTime},</if>
		<if test="batteryLevel != null">#{batteryLevel},</if>
		<if test="pressure != null">#{pressure},</if>
		<if test="status != null and status != ''">#{status},</if>
		<if test="createBy != null and createBy != ''">#{createBy},</if>
		sysdate()
		)
	</insert>

	<!-- 修改装置 -->
	<update id="updateDevice" parameterType="Device">
		update device
		<set>
			<if test="deviceId != null and deviceId != ''">device_id = #{deviceId},</if>
			<if test="name != null and name != ''">name = #{name},</if>
			<if test="type != null and type != ''">type = #{type},</if>
			<if test="lastComTime != null">last_com_time = #{lastComTime},</if>
			<if test="batteryLevel != null">battery_level = #{batteryLevel},</if>
			<if test="pressure != null">pressure = #{pressure},</if>
			<if test="status != null and status != ''">status = #{status},</if>
			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
			update_time = sysdate()
		</set>
		where id = #{id}
	</update>

	<!-- 删除装置 -->
	<delete id="deleteDeviceById" parameterType="Long">
		delete from device where id = #{id}
	</delete>

	<!-- 批量删除装置 -->
	<delete id="deleteDeviceByIds" parameterType="String">
		delete from device where id in
		<foreach collection="array" item="id" open="(" separator="," close=")">
			#{id}
		</foreach>
	</delete>

</mapper>